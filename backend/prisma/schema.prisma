// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// Users
// ============================================

enum Role {
  USER
  ADMIN
  TEACHER
}

model User {
  id          String   @id @default(cuid())
  firebaseUid String   @unique @map("firebase_uid")
  email       String   @unique
  username    String?  @unique
  firstName   String?  @map("first_name")
  lastName    String?  @map("last_name")
  photoURL    String?  @map("photo_url")
  role        Role     @default(USER)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  forumPosts      ForumPost[]
  forumComments   ForumComment[]
  forumFavorites  ForumFavorite[]
  ownedClubs      Club[]             @relation("ClubOwner")
  memberships     ClubMembership[]
  clubPosts       ClubPost[]
  blogPosts       BlogPost[]
  roadmapProgress RoadmapProgress[]
  labSubmissions  LabSubmission[]
  courses         Course[]
  enrollments     CourseEnrollment[]
  lessonProgress  LessonProgress[]
  quizAttempts    QuizAttempt[]
  bookmarks       CourseBookmark[]
  courseNotes     CourseNote[]
  stats           UserStats?

  @@map("users")
}

// ============================================
// Forum
// ============================================

model ForumPost {
  id        String   @id @default(cuid())
  title     String
  content   String
  code      String?
  authorId  String   @map("author_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  author    User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments  ForumComment[]
  favorites ForumFavorite[]

  @@index([authorId])
  @@index([createdAt(sort: Desc)])
  @@map("forum_posts")
}

model ForumComment {
  id        String   @id @default(cuid())
  content   String
  postId    String   @map("post_id")
  authorId  String   @map("author_id")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  post   ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User      @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([authorId])
  @@map("forum_comments")
}

// ============================================
// Clubs
// ============================================

model Club {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  imageURL    String?  @map("image_url")
  isApproved  Boolean  @default(false) @map("is_approved")
  ownerId     String   @map("owner_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  owner       User             @relation("ClubOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  memberships ClubMembership[]
  posts       ClubPost[]

  @@index([ownerId])
  @@map("clubs")
}

model ClubMembership {
  id       String   @id @default(cuid())
  userId   String   @map("user_id")
  clubId   String   @map("club_id")
  joinedAt DateTime @default(now()) @map("joined_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([userId, clubId])
  @@map("club_memberships")
}

model ClubPost {
  id        String   @id @default(cuid())
  content   String
  clubId    String   @map("club_id")
  authorId  String   @map("author_id")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  club   Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([clubId])
  @@map("club_posts")
}

// ============================================
// Blog
// ============================================

model BlogPost {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  content   String
  excerpt   String?
  coverURL  String?  @map("cover_url")
  published Boolean  @default(false)
  authorId  String   @map("author_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([published, createdAt(sort: Desc)])
  @@index([slug])
  @@map("blog_posts")
}

// ============================================
// Roadmaps
// ============================================

model Roadmap {
  id          String   @id @default(cuid())
  title       String
  description String?
  steps       Json     @default("[]")
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  progress RoadmapProgress[]

  @@map("roadmaps")
}

model RoadmapProgress {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  roadmapId      String   @map("roadmap_id")
  completedSteps Json     @default("[]")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  roadmap Roadmap @relation(fields: [roadmapId], references: [id], onDelete: Cascade)

  @@unique([userId, roadmapId])
  @@map("roadmap_progress")
}

// ============================================
// Labs
// ============================================

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum SubmissionStatus {
  PENDING
  REVIEWED
  APPROVED
  REJECTED
}

model Lab {
  id          String     @id @default(cuid())
  title       String
  description String?
  content     String?
  difficulty  Difficulty @default(BEGINNER)
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  // Relations
  submissions LabSubmission[]

  @@map("labs")
}

model LabSubmission {
  id        String           @id @default(cuid())
  labId     String           @map("lab_id")
  userId    String           @map("user_id")
  content   String
  status    SubmissionStatus @default(PENDING)
  feedback  String?
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  // Relations
  lab  Lab  @relation(fields: [labId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([labId, userId])
  @@map("lab_submissions")
}

// ============================================
// Additions
// ============================================

model ForumFavorite {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  postId    String   @map("post_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  post ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@map("forum_favorites")
}

// ============================================
// Courses & Learning (Enhanced)
// ============================================

enum LessonType {
  TEXT
  VIDEO
  INTERACTIVE
}

model Course {
  id             String     @id @default(cuid())
  title          String
  subtitle       String?
  description    String?
  imageURL       String?    @map("image_url")
  category       String?
  level          Difficulty @default(BEGINNER)
  estimatedHours Int?       @map("estimated_hours")
  tags           String[]   @default([])
  outcomes       String[]   @default([])
  prerequisites  String[]   @default([])
  isPublished    Boolean    @default(true) @map("is_published")
  authorId       String     @map("author_id")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  // Relations
  author      User               @relation(fields: [authorId], references: [id], onDelete: Cascade)
  modules     CourseModule[]
  lessons     Lesson[]
  enrollments CourseEnrollment[]
  quizzes     Quiz[]
  bookmarks   CourseBookmark[]
  notes       CourseNote[]

  @@index([category])
  @@index([level])
  @@index([isPublished, createdAt(sort: Desc)])
  @@map("courses")
}

model CourseModule {
  id          String   @id @default(cuid())
  title       String
  description String?
  order       Int      @default(0)
  courseId    String   @map("course_id")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@index([courseId, order])
  @@map("course_modules")
}

model Lesson {
  id         String     @id @default(cuid())
  title      String
  content    String?
  videoURL   String?    @map("video_url")
  duration   Int?       // minutes
  summary    String?
  lessonType LessonType @default(TEXT) @map("lesson_type")
  order      Int        @default(0)
  courseId   String     @map("course_id")
  moduleId   String?    @map("module_id")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  // Relations
  course   Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  module   CourseModule? @relation(fields: [moduleId], references: [id])
  progress LessonProgress[]
  notes    CourseNote[]

  @@index([courseId, order])
  @@map("lessons")
}

model CourseEnrollment {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  courseId   String   @map("course_id")
  enrolledAt DateTime @default(now()) @map("enrolled_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@map("course_enrollments")
}

model LessonProgress {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  lessonId    String   @map("lesson_id")
  courseId    String   @map("course_id")
  completedAt DateTime @default(now()) @map("completed_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId, courseId])
  @@map("lesson_progress")
}

// ============================================
// Quiz System
// ============================================

model Quiz {
  id           String   @id @default(cuid())
  title        String
  description  String?
  courseId     String   @map("course_id")
  passingScore Int      @default(70) @map("passing_score")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  course    Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  questions QuizQuestion[]
  attempts  QuizAttempt[]

  @@map("quizzes")
}

model QuizQuestion {
  id          String   @id @default(cuid())
  quizId      String   @map("quiz_id")
  text        String
  options     Json     // [{id: string, text: string, isCorrect: boolean}]
  explanation String?
  order       Int      @default(0)
  points      Int      @default(1)
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId, order])
  @@map("quiz_questions")
}

model QuizAttempt {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  quizId      String   @map("quiz_id")
  score       Int
  maxScore    Int      @map("max_score")
  passed      Boolean
  answers     Json     // [{questionId: string, selectedOptionId: string, isCorrect: boolean}]
  completedAt DateTime @default(now()) @map("completed_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([userId, quizId])
  @@map("quiz_attempts")
}

// ============================================
// Bookmarks & Notes
// ============================================

model CourseBookmark {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  courseId  String   @map("course_id")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@map("course_bookmarks")
}

model CourseNote {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  courseId  String   @map("course_id")
  lessonId  String?  @map("lesson_id")
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lesson Lesson? @relation(fields: [lessonId], references: [id])

  @@index([userId, courseId])
  @@map("course_notes")
}

// ============================================
// User Stats & Gamification
// ============================================

model UserStats {
  userId                String    @id @map("user_id")
  xp                    Int       @default(0)
  streak                Int       @default(0)
  lastStudiedAt         DateTime? @map("last_studied_at")
  totalLessonsCompleted Int       @default(0) @map("total_lessons_completed")
  totalQuizzesPassed    Int       @default(0) @map("total_quizzes_passed")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_stats")
}
