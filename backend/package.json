{
  "name": "astrohub-backend",
  "version": "1.0.0",
  "description": "AstroHub — Production-ready backend API",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^12.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@prisma/client": "^6.4.0",
    "@sentry/node": "^9.0.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.2.0",
    "jose": "^6.2.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.4.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
