# ============================================
# AstroHub Backend — Environment Variables
# ============================================
# Copy this file to .env and fill in the values.

# Server
PORT=4000
NODE_ENV=development
API_URL=http://localhost:4000

# Database (PostgreSQL)
DATABASE_URL=postgresql://astrohub:astrohub_dev@localhost:5432/astrohub?schema=public

# CORS — comma-separated allowed origins
# In production, set to your actual frontend domain
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Firebase Admin SDK
# Paste the ENTIRE JSON content of your Firebase service account key here (as a single line)
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# Admin emails — comma-separated list of emails that get admin role on first login
ADMIN_EMAILS=akhmk08@gmail.com

# Sentry (optional — leave empty to disable)
SENTRY_DSN=

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
