# ============================================
# AstroHub Backend — Environment Variables
# ============================================
# Copy this file to .env and fill in the values.

# Server
PORT=4000
NODE_ENV=development
API_URL=http://localhost:4000

# Database (PostgreSQL)
# Use Neon (free): https://neon.tech
# Or local Docker: postgresql://astrohub:astrohub_dev@localhost:5432/astrohub?schema=public
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# CORS — comma-separated allowed origins
# In production, set to your actual frontend domain
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Firebase — only the project ID is needed (no service account key required!)
# Find this in your firebase-applet-config.json under "projectId"
FIREBASE_PROJECT_ID=your-firebase-project-id

# Admin emails — comma-separated list of emails that get admin role on first login
ADMIN_EMAILS=admin@example.com

# Sentry (optional — leave empty to disable)
SENTRY_DSN=

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
