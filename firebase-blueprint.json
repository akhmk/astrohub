{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user profile information and roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user." },
        "email": { "type": "string", "format": "email", "description": "User's email address." },
        "displayName": { "type": "string", "description": "User's display name." },
        "photoURL": { "type": "string", "format": "uri", "description": "URL to user's profile picture." },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "User's role in the system." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user account was created." }
      },
      "required": ["uid", "email", "role"]
    },
    "Course": {
      "title": "Course",
      "description": "Represents an educational course.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "instructor": { "type": "string" },
        "duration": { "type": "string" },
        "students": { "type": "string" },
        "rating": { "type": "number" },
        "image": { "type": "string", "format": "uri" },
        "category": { "type": "string" },
        "level": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["title", "instructor", "image"]
    },
    "Post": {
      "title": "Forum Post",
      "description": "A discussion post in the forum.",
      "type": "object",
      "properties": {
        "authorUid": { "type": "string" },
        "authorName": { "type": "string" },
        "authorAvatar": { "type": "string", "format": "uri" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "code": { "type": "string" },
        "likes": { "type": "number" },
        "commentsCount": { "type": "number" },
        "shares": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorUid", "title", "content", "createdAt"]
    },
    "Club": {
      "title": "Club",
      "description": "A community group or club.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "membersCount": { "type": "number" },
        "image": { "type": "string", "format": "uri" },
        "category": { "type": "string" }
      },
      "required": ["name", "description", "image"]
    },
    "BlogPost": {
      "title": "Blog Post",
      "description": "An article in the blog section.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "excerpt": { "type": "string" },
        "content": { "type": "string" },
        "author": { "type": "string" },
        "image": { "type": "string", "format": "uri" },
        "publishedAt": { "type": "string", "format": "date-time" },
        "tags": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["title", "content", "author", "publishedAt"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/courses/{courseId}": {
      "schema": "Course",
      "description": "Course catalog."
    },
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Forum discussions."
    },
    "/clubs/{clubId}": {
      "schema": "Club",
      "description": "Community clubs."
    },
    "/blog/{blogId}": {
      "schema": "BlogPost",
      "description": "Blog articles."
    }
  }
}
